{
  "name": "samsung-device-helper",
  "version": "0.0.23",
  "description": "A utility to help you identify Samsung devices",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsup",
    "pretest": "tsc -p tests",
    "test": "mocha",
    "coverage": "tsc -p tests && c8 mocha",
    "prepack": "yarn run build",
    "pack": "yarn pack",
    "publish": "yarn publish",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "release": "bash scripts/release.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kulcsarrudolf/samsung-device-helper.git"
  },
  "keywords": [
    "samsung",
    "device",
    "helper",
    "utility",
    "device identification",
    "device model",
    "device name",
    "device type"
  ],
  "author": "Kulcsár Rudolf",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kulcsarrudolf/samsung-device-helper/issues"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.4.2",
    "@types/sinon": "^10.0.15",
    "c8": "^10",
    "chai": "^4.3.7",
    "chalk": "^4.1.2",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mocha": "^10.2.0",
    "prettier": "^3.8.1",
    "sinon": "^15.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
